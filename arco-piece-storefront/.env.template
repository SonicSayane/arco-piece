# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# Backend Medusa server URL (server-side). Update for production deploys.
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable key for the storefront sales channel.
# Generate one in Medusa admin → Settings → Publishable API Keys.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Public storefront URL (used for canonical, OpenGraph, sitemap).
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Default country code (ISO-2 lowercase) when geolocation cannot be determined.
NEXT_PUBLIC_DEFAULT_REGION=ne
NEXT_PUBLIC_SECONDARY_REGION=fr

# Stripe publishable (client) key.
NEXT_PUBLIC_STRIPE_KEY=

# On-demand revalidation secret (server-side). MUST be a strong random string in prod.
REVALIDATE_SECRET=

# Optional: Medusa Cloud S3 hostname/pathname for image optimization.
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=

# Optional: phone number (digits only, international format) shown by the
# floating WhatsApp CTA. Leave empty to hide the button.
# Example: 22790000000
NEXT_PUBLIC_WHATSAPP_PHONE=

# Optional: enable the locale switcher (requires backend locales endpoint).
NEXT_PUBLIC_ENABLE_LOCALES=false
